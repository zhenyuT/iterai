ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Optional: use a custom API endpoint (e.g. a proxy)
# ANTHROPIC_BASE_URL=https://your-custom-endpoint.com

# Optional: route requests through an HTTP/HTTPS proxy (e.g. Charles)
# HTTPS_PROXY=http://127.0.0.1:8889

# Optional: trust a custom CA certificate (e.g. Charles SSL Proxying certificate)
# NODE_EXTRA_CA_CERTS=~/charles-ssl-proxying-certificate.pem
